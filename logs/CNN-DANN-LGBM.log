                        Xte, yte = extract_cnn_features(model, test_loader,  device, dann=True)
                        _clf, mtr, mva, mte = train_eval_lgbm(Xtr, ytr, Xva, yva, Xte, yte)
                        # --- per-trial best モデル保存（CNN best_state + LGBMヘッド + メタ）---
                        import joblib as _joblib
                        _m = model.module if isinstance(model, torch.nn.DataParallel) else model
                        _pkg = {"model": "cnn_dann_lgbm", "trial": int(trial.number), "epoch": int(best_epoch),
                                "cnn_valid_auc": float(best_val_auc), "lgbm_valid_auc": float(mva["auc"]),
                                "params": dict(trial.params),
                                "cnn_state_dict": {k: v.detach().cpu().clone() for k, v in _m.state_dict().items()},
                                "lgbm_head": _clf}
                        os.makedirs("optuna_models", exist_ok=True)
                        _joblib.dump(_pkg, f"optuna_models/cnn_dann_lgbm_{n}_trial{int(trial.number)}_best.pkl")
                        if float(mva["auc"]) > _GLOBAL_BEST_AUC[0]:
                            _GLOBAL_BEST_AUC[0] = float(mva["auc"])
                            _joblib.dump(_pkg, f"optuna_models/cnn_dann_lgbm_{n}_best.pkl")
                        row_id = append_result_row(
                            pref=n,
                            best_epoch=best_epoch,
                            lr=lr,
                            weight_decay=weight_decay,
                            batch_size=batch_size,
                            m1_size=m1_size,
                            m2_size=m2_size,
                            dropout=dropout,
                            base_ch=base_ch,
                            alpha=alpha,
                            y_train=y_train,
                            y_valid=y_valid,
                            y_test=y_test,
                            cnn_val_auc=best_val_auc,
                            cnn_test_auc=best_test_auc,
                            lgbm_train=mtr,
                            lgbm_valid=mva,
                            lgbm_test=mte,
                        )

                        datalist = [
                            train_loss_list, valid_loss_list, test_loss_list,
                            train_acc_list, valid_acc_list, test_acc_list,
                            train_positive_list, valid_positive_list, test_positive_list,
                            train_F1_list, valid_F1_list, test_F1_list,
                            train_auc_list, valid_auc_list, test_auc_list,
                            train_meanscore_list, valid_meanscore_list, test_meanscore_list, train_prauc_list, valid_prauc_list, test_prauc_list,
                        ]

                        seve_metrics(f"CNN-DANN-LGBM-県を予測-optuna-{row_id}", datalist=datalist)

                        del model
                        del optimizer
                        torch.cuda.empty_cache()
                        gc.collect()

                        return mva["auc"]

                # 正常終了
                # CNN特徴抽出 → LightGBM
                if best_state is not None:
                    model.load_state_dict(best_state)
                Xtr, ytr = extract_cnn_features(model, train_loader, device, dann=True)
                Xva, yva = extract_cnn_features(model, valid_loader, device, dann=True)
                Xte, yte = extract_cnn_features(model, test_loader,  device, dann=True)
                _clf, mtr, mva, mte = train_eval_lgbm(Xtr, ytr, Xva, yva, Xte, yte)
                row_id = append_result_row(
                    pref=n,
                    best_epoch=best_epoch,
                    lr=lr,
                    weight_decay=weight_decay,
                    batch_size=batch_size,
                    m1_size=m1_size,
                    m2_size=m2_size,
                    dropout=dropout,
                    base_ch=base_ch,
                    alpha=alpha,
                    y_train=y_train,
                    y_valid=y_valid,
                    y_test=y_test,
                    cnn_val_auc=best_val_auc,
                    cnn_test_auc=best_test_auc,
                    lgbm_train=mtr,
                    lgbm_valid=mva,
                    lgbm_test=mte,
                )

                datalist = [
                    train_loss_list, valid_loss_list, test_loss_list,
                    train_acc_list, valid_acc_list, test_acc_list,
                    train_positive_list, valid_positive_list, test_positive_list,
                    train_F1_list, valid_F1_list, test_F1_list,
                    train_auc_list, valid_auc_list, test_auc_list,
                    train_meanscore_list, valid_meanscore_list, test_meanscore_list, train_prauc_list, valid_prauc_list, test_prauc_list,
                ]

                seve_metrics(f"CNN-DANN-LGBM-県を予測-optuna-{row_id}", datalist=datalist)

                del model
                del optimizer
                torch.cuda.empty_cache()
                gc.collect()

                return mva["auc"]

            except torch.cuda.OutOfMemoryError as e:
                print(f"[Trial {trial.number}] CUDA OOM on attempt {attempt}/{MAX_RETRIES_PER_TRIAL}: {e}")

            except RuntimeError as e:
                if "out of memory" in str(e).lower():
                    print(f"[Trial {trial.number}] RuntimeError OOM on attempt {attempt}/{MAX_RETRIES_PER_TRIAL}: {e}")
                else:
                    raise

            # OOM 後の後始末
            model = None
            optimizer = None
            train_loader_for_train = None
            target_loader_for_train = None
            train_loader = None
            valid_loader = None
            test_loader = None

            torch.cuda.empty_cache()
            gc.collect()

            if attempt == MAX_RETRIES_PER_TRIAL:
                print(f"[Trial {trial.number}] Reached max OOM retries. Pruning trial.")
                raise optuna.TrialPruned()

            print(f"[Trial {trial.number}] Waiting {WAIT_SECONDS} seconds before retry...")
            time.sleep(WAIT_SECONDS)

    study = optuna.create_study(
        study_name=f"DANN_fold_{n}",
        direction="maximize",
        sampler=optuna.samplers.TPESampler(seed=SEED),
        pruner=MedianPruner(n_startup_trials=5, n_warmup_steps=5),
    )
    study.optimize(objective, n_trials=5, gc_after_trial=True, n_jobs=1)
